grp_data = "📡 Data Sources"
trading_safe_mode = input.bool(true, "🛡️ Trading Safe Mode (Recommended)", group=grp_data, tooltip="ON: 实盘安全模式 Trading-safe\n    • 信号无重绘 Signals no repaint\n    • 面板VIX实时显示(ʳᵗ) Dashboard VIX real-time\nOFF: 预览模式 Preview mode\n    • 历史可能重绘 History may repaint")

sym_vix_input = input.symbol("CBOE:VIX", "VIX Symbol", group=grp_data, tooltip="VIX数据源 VIX data source\n默认 Default: CBOE:VIX")
vix_timeframe = input.string("Daily", "VIX Timeframe", options=["Daily", "Chart"], group=grp_data, tooltip="Daily: 日线结构源 daily structure source (稳定 stable)\nChart: VIX显示/波动区间门控/自适应趋势均线选择(实时趋势过滤)/自适应冷却跟随图表周期 VIX display, regime gating, adaptive trend-MA selection (live trend filter) and adaptive cooldown follow the chart timeframe\nv7.13起评分始终基于日线结构计算 Since v7.13 Score is always computed on daily structure data")
sym_pcr_input = input.symbol("INDEX:CPCI", "Put/Call Ratio Symbol", group=grp_data, tooltip="看跌/看涨比率 Put/Call Ratio\n默认 Default: INDEX:CPCI (指数期权 Index options)")
