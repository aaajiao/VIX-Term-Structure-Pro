sell_strictness = input.string("Balanced (Legacy)", "Sell Signal Strictness", options=["Balanced (Legacy)", "High Win-Rate"], group=grp_strategy, tooltip="Balanced (Legacy): 保持当前卖出过滤 Keep current sell behavior\nHigh Win-Rate: 更少但更准 Fewer but cleaner top signals")
use_trend_filter = input.bool(true, "🛡️ Market Trend Filter", group=grp_strategy, tooltip="ON: 熊市过滤信号展示 Filter signal display in bear market\n    • BUY DIP → NO TRADE（被过滤 filtered）\n    • STRONG BUY / CRASH BUY 不受限制 Not filtered\n    • Score 不受影响 Score unchanged\nOFF: 所有信号正常显示 All signals shown")
auto_detect_index = input.bool(true, "Auto-Detect Index (Based on Chart)", group=grp_strategy, tooltip="ON: 自动检测 Auto-detect (QQQ→NDX, IWM→RUT, 其他→SPX)\n    • 影响趋势过滤和统计收益 Affects trend filter & stats returns\n    • 不影响 Score（纯VIX结构） Score unchanged (pure VIX)\nOFF: 使用手动趋势源 Use manual trend source")

// 自适应趋势过滤器设置 (v7.1 新增)
trend_ma_mode = input.string("Adaptive", "Trend MA Mode", options=["Fixed", "Adaptive", "KAMA"], group=grp_strategy, tooltip="Fixed: 固定均线 Fixed MA\nAdaptive: 波动自适应 Vol-adaptive\nKAMA: 效率自适应 Efficiency-adaptive")
trend_ma_type = input.string("SMA", "└─ Fixed MA Type", options=["SMA", "EMA"], group=grp_strategy, tooltip="仅Fixed模式 For Fixed mode only\nSMA: 稳定 Stable / EMA: 灵敏 Responsive")
trend_ma_length_high = input.int(100, "└─ Adaptive Length (High Vol)", minval=20, maxval=200, group=grp_strategy, tooltip="高波动期均线长度 MA length for high vol\n更短=更敏感 Shorter=more sensitive")
trend_ma_length_low = input.int(200, "└─ Adaptive/Fixed Length (Low Vol)", minval=100, maxval=500, group=grp_strategy, tooltip="低波动期/Fixed默认长度 MA length for low vol/Fixed\n更长=更平滑 Longer=smoother")
kama_length = input.int(21, "└─ KAMA Length", minval=5, maxval=50, group=grp_strategy, tooltip="KAMA计算周期 KAMA lookback\n较短=反应更快 Shorter=faster response")

// ────────────────────────────────────────────────────────────────────────────
