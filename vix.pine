//@version=6
// calc_bars_count uses a fixed 5000-bar execution window to stay within Pine's common historical buffer.
indicator("VIX Term Structure Pro [v7.13]", overlay=false, max_lines_count=500, calc_bars_count=5000)

// ╔════════════════════════════════════════════════════════════════════════════╗
// ║                    VIX Term Structure Pro v7.13 使用指南                     ║
// ╠════════════════════════════════════════════════════════════════════════════╣
// ║ 📊 仪表盘指标解读                                                           ║
// ║----------------------------------------------------------------------------║
// ║ 指标           │ 看涨信号 🟢              │ 看跌信号 🔴                     ║
// ║----------------------------------------------------------------------------║
// ║ Overall Bias   │ STRONG BUY / BUY DIP    │ STRONG SELL / SELL/HEDGE       ║
// ║ AI Score       │ ≥ 5 (极度恐慌)           │ ≤ -5 (极度贪婪)                 ║
// ║ Market Trend   │ 🟢SPX 🟢NDX 🟢RUT       │ 🔴SPX 🔴NDX 🔴RUT               ║
// ║ VIX Regime     │ LOW VOL (<15)           │ HIGH VOL (>25)                 ║
// ║ Term Struct Z  │ < -2.0 (恐慌)           │ > 2.0 (贪婪)                    ║
// ║----------------------------------------------------------------------------║
// ║ 💡 状态提示说明 (Status)                                                    ║
// ║----------------------------------------------------------------------------║
// ║ WAIT (等待)    │ 🟡 买入侧。评分达标但被过滤（如高波动或动量未确认）。        ║
// ║                │ 含义：不要急于进场，等待更好的时机。                        ║
// ║ HOLD (持有)    │ 🟠 卖出侧。评分达标但被过滤（如低波动或动量未确认）。        ║
// ║                │ 含义：不要急于卖出/对冲，继续持有仓位。                      ║
// ╠════════════════════════════════════════════════════════════════════════════╣
// ║ 📌 v7.8 新增功能 (Dashboard Redesign)                                       ║
// ║----------------------------------------------------------------------------║
// ║ 🎨 全新仪表盘    │ Mobile/Full 双模式，深色主题，分组布局                    ║
// ║ 📊 进度条显示    │ Score 可视化进度条 (█░)                                  ║
// ║ 🛡️ 实盘安全模式  │ 默认开启，无重绘 (lookahead_off)                         ║
// ║ ⬆️ 跨K线升级报警  │ 信号等级升级时触发新警报 (DIP→STRONG→CRASH)              ║
// ╚════════════════════════════════════════════════════════════════════════════╝

// ========== 评分函数定义 (模块化) ==========
calc_z_score_points(z_val, mid, strong) =>
    z_val < -strong ? 4 : z_val < -mid ? 2 : z_val > strong ? -4 : z_val > mid ? -2 : 0

calc_contango_points(contango) =>
    contango < 0 ? 2 : contango > 10 ? -1 : 0

calc_basis_points(is_panic, is_calm) =>
    is_panic ? 2 : is_calm ? -1 : 0

calc_skew_points(is_high, is_low) =>
    is_high ? -3 : is_low ? 1 : 0

calc_pcr_points(is_panic, is_calm) =>
    is_panic ? 2 : is_calm ? -2 : 0

calc_vvix_points(is_panic, is_calm, use_vvix) =>
    not use_vvix ? 0 : is_panic ? 1 : is_calm ? -1 : 0

// ========== v7.8: 进度条生成函数 ==========
// 生成 Score 进度条 (-10 到 +10 范围，10格)
f_score_bar(score_val) =>
    clamped = math.max(-10.0, math.min(10.0, score_val))
    filled = math.round((clamped + 10.0) / 20.0 * 10.0)
    string bar = ""
    for i = 0 to 9
        bar := bar + (i < filled ? "█" : "░")
    bar

f_stats_cell(icon, evaluated_count, win_rate, avg_return, ready) =>
    ready ? icon + str.tostring(evaluated_count) + " W" + str.tostring(win_rate, "#") + "% " + str.tostring(avg_return, "+#.#;-#.#") + "%" : icon + "N/A"

// ========== KAMA 自定义实现 (Kaufman Adaptive Moving Average) ==========
// 由于 ta.kama() 在某些环境不可用，手动实现
calc_kama(src, length, fastLen, slowLen) =>
    // 计算效率比率 (Efficiency Ratio)
    change_sum = math.abs(src - src[length])
    volatility = math.sum(math.abs(src - src[1]), length)
    er = volatility != 0 ? change_sum / volatility : 0.0
    // 计算平滑常数 (Smoothing Constant)
    fast_sc = 2.0 / (fastLen + 1)
    slow_sc = 2.0 / (slowLen + 1)
    sc = math.pow(er * (fast_sc - slow_sc) + slow_sc, 2)
    // 计算 KAMA (递归)
    var float kama = na
    kama := na(kama[1]) ? src : kama[1] + sc * (src - kama[1])
    kama

