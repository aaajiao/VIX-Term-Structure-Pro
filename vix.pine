// 19*252 + 60 = 4848, which stays within the 5000-bar execution / buffer budget. 20Y would exceed it.
stats_lookback_years = input.int(3, "Stats Lookback (Years)", minval=1, maxval=19, group=grp_stats, tooltip="统计回溯年数 Stats lookback years\n仅统计此范围内信号 Only count signals within range\n上限19年以避免超过5000 bars 19Y max keeps stats inside 5000 bars")
crash_return_bars = input.int(40, "🚨 CRASH Return Period (Bars)", minval=10, maxval=60, group=grp_stats, tooltip="CRASH信号收益周期 CRASH return period\n约2个月 ~2 months")
strong_return_bars = input.int(20, "🟢 STRONG Return Period (Bars)", minval=10, maxval=40, group=grp_stats, tooltip="STRONG信号收益周期 STRONG return period\n约1个月 ~1 month")
dip_return_bars = input.int(10, "🟡 DIP Return Period (Bars)", minval=5, maxval=20, group=grp_stats, tooltip="DIP信号收益周期 DIP return period\n约2周 ~2 weeks")
enable_smart_alert = input.bool(true, "🔔 Smart Alert", group=grp_stats, tooltip="启用智能警报 Enable Smart Alert\n单条消息汇总所有信号 Aggregated signal message")
alert_timing_mode = input.string("Confirmed Daily Structure", "└─ Alert Timing Mode", options=["Confirmed Daily Structure", "Preview / Earliest Possible"], group=grp_stats, tooltip="Confirmed Daily Structure: 严格使用已完成的上一结构日 Strict previous completed structure day\n盘中只在下一次常规时段发出一次 confirmed Confirmed emits once on the next regular session\nPreview / Earliest Possible: 尽早预览 Hybrid preview\n可能仍受日线结构源更新时间影响 May still depend on delayed daily source updates")
after_hours_alert_policy = input.string("Allow if source confirms", "└─ After-Hours Alert Policy", options=["Allow if source confirms", "Regular Session Only"], group=grp_stats, tooltip="Preview 模式使用 Used by Preview mode\nAllow if source confirms: 允许盘后预览提醒 Allow preview alerts after close\nRegular Session Only: 使用交易所常规时段，常规时段外不提醒 Use exchange-defined regular market hours; block alerts outside the regular session")
alert_cooldown_base = input.int(5, "Alert Cooldown Base (Bars)", minval=1, maxval=20, group=grp_stats, tooltip="基础冷却间隔 Base cooldown (bars)\n高波动期减半、低波动期加倍 Halved in high vol, doubled in low vol\n注意: 被冷却或时段策略拦截的信号会被直接丢弃, 不会延后补发 Note: signals blocked by cooldown or session policy are DISCARDED, never deferred or re-sent")
alert_freq_mode = input.string("Real-time", "└─ Alert Frequency", options=["Once Per Bar", "Real-time"], group=grp_stats, tooltip="Once Per Bar: 每K线最多一次 Max once per bar\nReal-time: 实时触发 Trigger on every condition")
alert_freq = alert_freq_mode == "Real-time" ? alert.freq_all : alert.freq_once_per_bar

// ────────────────────────────────────────────────────────────────────────────
// ⚙️ 高级设置 (Advanced Settings)
// ────────────────────────────────────────────────────────────────────────────
grp_advanced = "⚙️ Advanced Settings"

// VIX Regime 阈值
vix_low_thresh = input.float(15.0, "VIX Low Vol Threshold", minval=10, maxval=20, group=grp_advanced, tooltip="低波动阈值 Low vol threshold\n低于此值=LOW VOL Below=LOW VOL")
vix_high_thresh = input.float(25.0, "VIX High Vol Threshold", minval=20, maxval=40, group=grp_advanced, tooltip="高波动阈值 High vol threshold\n高于此值=HIGH VOL Above=HIGH VOL")

// 自适应阈值
use_adaptive_thresholds = input.bool(true, "Use Adaptive Thresholds", group=grp_advanced, tooltip="自适应阈值 Adaptive thresholds\n使用百分位动态阈值 Use percentile-based thresholds")
adapt_lookback = input.int(252, "Adaptive Lookback Period", minval=50, maxval=500, group=grp_advanced, tooltip="自适应回溯周期 Adaptive lookback\n252=1年 1 year")

// Z-Score 计算
use_adaptive = input.bool(true, "Use Adaptive Lookback (Z-Score)", group=grp_advanced, tooltip="Z-Score自适应回溯 Adaptive Z lookback\n高波动期用短周期 Shorter in high vol")
len_low      = input.int(252, "Lookback (Low Vol)", minval=50, group=grp_advanced, tooltip="低波动回溯 Low vol lookback\n252=1年 1 year")
len_high     = input.int(126, "Lookback (High Vol)", minval=20, group=grp_advanced, tooltip="高波动回溯 High vol lookback\n126=半年 6 months")
vol_thresh   = input.float(20.0, "Vol Regime Threshold", minval=10, group=grp_advanced, tooltip="波动区间阈值 Vol regime threshold\nVIX高于此值=高波动期 Above=high vol")
vol_hysteresis = input.float(0.0, "└─ Vol Regime Hysteresis Band", minval=0.0, maxval=10.0, step=0.5, group=grp_advanced, tooltip="波动切换滞回带 Hysteresis band for Z lookback switching\nVIX高于 阈值+带宽 才切到高波动回溯, 回到 阈值-带宽 及以下才切回 Switch to high-vol lookback only above threshold+band, switch back only at or below threshold-band\n0 = 即时切换 (默认, 与 v7.12 行为一致) 0 = instant switching (default, matches v7.12)\n建议试验值 Suggested value to try: 2.0")

// SKEW 设置
skew_mode    = input.string("Relative (Z-Score)", "SKEW Logic Mode", options=["Relative (Z-Score)", "Percentile (Adaptive)", "Absolute (>140)"], group=grp_advanced, tooltip="SKEW判断模式 SKEW logic mode\nZ-Score: 相对标准差 / Percentile: 百分位 / Absolute: 固定值")
skew_len     = input.int(126, "SKEW Lookback Period", minval=20, group=grp_advanced, tooltip="SKEW回溯周期 SKEW lookback\n126=半年 6 months")

// 成交量设置
vol_avg_len  = input.int(20, "Volume Avg Length", minval=5, group=grp_advanced, tooltip="成交量均线长度 Volume MA length")

// ────────────────────────────────────────────────────────────────────────────
// 📈 VVIX 设置 (Optional)
// ────────────────────────────────────────────────────────────────────────────
grp_vvix = "📈 VVIX (Optional)"
use_vvix = input.bool(false, "Enable VVIX Integration", group=grp_vvix, tooltip="启用VVIX Enable VVIX\nVVIX=VIX的波动率 VIX of VIX")
vvix_threshold_mode = input.string("Z-Score", "VVIX Threshold Mode", options=["Fixed", "Percentile", "Z-Score"], group=grp_vvix, tooltip="Fixed: 固定阈值 Fixed (130/80)\nPercentile: 百分位 90/10 percentile\nZ-Score: 标准差 ±2 std dev")
vvix_z_thresh = input.float(2.0, "└─ Z-Score Threshold", minval=1.0, maxval=3.0, step=0.1, group=grp_vvix, tooltip="VVIX Z阈值 Z threshold\n>阈值=恐慌 Panic / <-阈值=平静 Calm")
vvix_panic_thresh = input.float(130.0, "└─ Fixed Panic Threshold", minval=100, maxval=160, group=grp_vvix, tooltip="Fixed模式恐慌阈值 Fixed panic threshold\n仅Fixed模式 For Fixed mode only")
vvix_calm_thresh = input.float(80.0, "└─ Fixed Calm Threshold", minval=60, maxval=100, group=grp_vvix, tooltip="Fixed模式平静阈值 Fixed calm threshold\n仅Fixed模式 For Fixed mode only")

// ────────────────────────────────────────────────────────────────────────────
// 内部计算参数（基于策略模式）
// ────────────────────────────────────────────────────────────────────────────
smooth_dyn = sens_mode == "High (Scalping)" ? 3 : sens_mode == "Normal (Swing)" ? 5 : 8
thresh_strong = sens_mode == "High (Scalping)" ? 2.0 : sens_mode == "Normal (Swing)" ? 2.2 : 2.5
thresh_mid = sens_mode == "High (Scalping)" ? 1.0 : sens_mode == "Normal (Swing)" ? 1.2 : 1.5
min_score_buy = sens_mode == "High (Scalping)" ? 2 : sens_mode == "Normal (Swing)" ? 3 : 4

t_size = table_size == "Small" ? size.small : table_size == "Large" ? size.large : size.normal
is_mobile = panel_mode == "Mobile"

// ========== 2. 数据获取 ==========
// v7.9: Trading Safe Mode 默认开启，使用 lookahead_off 避免重绘
// Trading Safe Mode ON (默认): 信号无重绘，面板VIX实时显示
// Trading Safe Mode OFF: 盘中实时预览，但历史可能重绘
vix_tf = vix_timeframe == "Daily" ? "D" : ""
is_no_repaint_mode = trading_safe_mode
lookahead_setting = is_no_repaint_mode ? barmerge.lookahead_off : barmerge.lookahead_on

vix     = request.security(sym_vix_input, vix_tf, close, lookahead=lookahead_setting, ignore_invalid_symbol=true)

// v7.9: 面板显示专用的实时 VIX（不影响信号计算）
// 最后一根K线用 vix_rt（实时），历史K线用 vix（避免重绘）
vix_rt = request.security(sym_vix_input, vix_tf, close, lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
vix_display = barstate.islast ? vix_rt : vix
// v7.13: 结构日ID表达式；在日线 security 上下文中按 SPX 日线日期求值 / Structure-day id; re-evaluates to the SPX daily date inside the "D" security context
day_id_src = year * 10000 + month * 100 + dayofmonth

// v7.13: VX1 收盘+成交量合并为单次 tuple 请求，控制 request.*() 唯一调用数（上限40，嵌套上下文会重复计数）
// v7.13: VX1 close+volume packed into one tuple request to control unique request.*() count (limit 40; nested contexts re-count inner calls)
[vx1, vx1_vol] = request.security("CBOE:VX1!", "D", [close, volume], lookahead=lookahead_setting, ignore_invalid_symbol=true)
vx2     = request.security("CBOE:VX2!", "D", close, lookahead=lookahead_setting, ignore_invalid_symbol=true)
skew    = request.security("CBOE:SKEW", "D", close, lookahead=lookahead_setting, ignore_invalid_symbol=true)
pcr     = request.security(sym_pcr_input, "D", close, lookahead=lookahead_setting, ignore_invalid_symbol=true)

// VVIX 数据 (可选)
vvix = use_vvix ? request.security("CBOE:VVIX", "D", close, lookahead=lookahead_setting, ignore_invalid_symbol=true) : na

// 自动检测逻辑：如果图表是 QQQ/NQ/NDX 相关，用 NDX；如果是 IWM/RUT/RTY 相关，用 RUT；否则用 SPX
is_nasdaq_chart = str.contains(str.upper(syminfo.ticker), "QQQ") or 
                  str.contains(str.upper(syminfo.ticker), "NDX") or 
                  str.contains(str.upper(syminfo.ticker), "NQ")
is_russell_chart = str.contains(str.upper(syminfo.ticker), "IWM") or 
                   str.contains(str.upper(syminfo.ticker), "RUT") or 
                   str.contains(str.upper(syminfo.ticker), "RTY")

// ========== 2.1 自适应趋势均线计算 (v7.1 新增, v7.7 统一 lookahead) ==========
// 根据 VIX 水平确定自适应均线长度
is_high_vol_regime = not na(vix) and vix > vol_thresh
adaptive_ma_len = is_high_vol_regime ? trend_ma_length_high : trend_ma_length_low

// v7.7: 趋势均线也统一使用 lookahead_setting，确保回测/实盘模式一致
// v7.13: 每个指数的收盘价+全部趋势均线合并为单次 tuple 请求（原 5 个调用 → 1 个），
// 否则两个日线上下文 tuple 会按嵌套上下文重复计数这些内层请求，突破 40 个 request.*() 上限
// v7.13: Each index's close + all trend MAs packed into ONE tuple request (was 5 calls -> 1);
// otherwise the two daily-context tuples re-count these inner calls per nested context and blow the 40 request.*() limit
f_trend_pack(string ma_type, int len_low, int len_high, int kama_len) =>
    // CW10003: ta.* 每根K线都先计算，再用三元选择；len_low 的 SMA 与 ma_adapt_low 复用同一次计算
    // CW10003: call ta.* on every bar first, then select; the len_low SMA is shared with ma_adapt_low
    ma_ema_fixed = ta.ema(close, len_low)
    ma_adapt_high = ta.sma(close, len_high)
    ma_adapt_low = ta.sma(close, len_low)
    ma_fixed = ma_type == "EMA" ? ma_ema_fixed : ma_adapt_low
    ma_kama = calc_kama(close, kama_len, 2, 30)
    [close, ma_fixed, ma_adapt_high, ma_adapt_low, ma_kama]

[spx_close, spx_ma_fixed, spx_ma_adapt_high, spx_ma_adapt_low, spx_ma_kama] = request.security("SP:SPX", "D", f_trend_pack(trend_ma_type, trend_ma_length_low, trend_ma_length_high, kama_length), lookahead=lookahead_setting, ignore_invalid_symbol=true)
[ndx_close, ndx_ma_fixed, ndx_ma_adapt_high, ndx_ma_adapt_low, ndx_ma_kama] = request.security("NASDAQ:NDX", "D", f_trend_pack(trend_ma_type, trend_ma_length_low, trend_ma_length_high, kama_length), lookahead=lookahead_setting, ignore_invalid_symbol=true)
[rut_close, rut_ma_fixed, rut_ma_adapt_high, rut_ma_adapt_low, rut_ma_kama] = request.security("TVC:RUT", "D", f_trend_pack(trend_ma_type, trend_ma_length_low, trend_ma_length_high, kama_length), lookahead=lookahead_setting, ignore_invalid_symbol=true)
[manual_close, manual_ma_fixed, manual_ma_adapt_high, manual_ma_adapt_low, manual_ma_kama] = request.security(manual_trend_src, "D", f_trend_pack(trend_ma_type, trend_ma_length_low, trend_ma_length_high, kama_length), lookahead=lookahead_setting, ignore_invalid_symbol=true)

// 根据模式选择最终使用的均线
spx_trend_ma = trend_ma_mode == "KAMA" ? spx_ma_kama : trend_ma_mode == "Adaptive" ? (is_high_vol_regime ? spx_ma_adapt_high : spx_ma_adapt_low) : spx_ma_fixed
ndx_trend_ma = trend_ma_mode == "KAMA" ? ndx_ma_kama : trend_ma_mode == "Adaptive" ? (is_high_vol_regime ? ndx_ma_adapt_high : ndx_ma_adapt_low) : ndx_ma_fixed
rut_trend_ma = trend_ma_mode == "KAMA" ? rut_ma_kama : trend_ma_mode == "Adaptive" ? (is_high_vol_regime ? rut_ma_adapt_high : rut_ma_adapt_low) : rut_ma_fixed
manual_trend_ma = trend_ma_mode == "KAMA" ? manual_ma_kama : trend_ma_mode == "Adaptive" ? (is_high_vol_regime ? manual_ma_adapt_high : manual_ma_adapt_low) : manual_ma_fixed

valid_data = not na(vix) and not na(vx1) and not na(vx2)

// ========== 3. 核心计算 ==========
// SPX 趋势判断（使用自适应趋势均线）
is_spx_bull = not na(spx_close) and not na(spx_trend_ma) ? (spx_close > spx_trend_ma) : true
// NDX 趋势判断
is_ndx_bull = not na(ndx_close) and not na(ndx_trend_ma) ? (ndx_close > ndx_trend_ma) : true
// RUT 趋势判断
is_rut_bull = not na(rut_close) and not na(rut_trend_ma) ? (rut_close > rut_trend_ma) : true
// 手动趋势源判断（v7.13: 拆为独立变量，供 confirmed 快照 tuple 复用 standalone manual trend gate, reused by the confirmed snapshot tuple）
is_manual_bull = not na(manual_close) and not na(manual_trend_ma) ? (manual_close > manual_trend_ma) : true

// 主趋势判断（用于评分系统的过滤）
is_auto_bull = is_russell_chart ? is_rut_bull : is_nasdaq_chart ? is_ndx_bull : is_spx_bull
is_primary_bull = auto_detect_index ? is_auto_bull : is_manual_bull

// 趋势状态文本（三指数合并显示）
spx_emoji = is_spx_bull ? "🟢" : "🔴"
ndx_emoji = is_ndx_bull ? "🟢" : "🔴"
rut_emoji = is_rut_bull ? "🟢" : "🔴"
trend_status_txt = spx_emoji + "SPX " + ndx_emoji + "NDX " + rut_emoji + "RUT"
trend_color = is_spx_bull and is_ndx_bull and is_rut_bull ? color.green : 
              not is_spx_bull and not is_ndx_bull and not is_rut_bull ? color.red : color.orange

// 用于评分的 is_bull_market（使用主趋势）
is_bull_market = is_primary_bull

// VIX Regime 判断
vix_regime = vix < vix_low_thresh ? 1 : vix > vix_high_thresh ? 3 : 2
vix_regime_txt = vix_regime == 1 ? "LOW" : vix_regime == 3 ? "HIGH" : "NORM"
vix_regime_color = vix_regime == 1 ? color.lime : vix_regime == 3 ? color.red : color.silver
vix_regime_emoji = vix_regime == 1 ? "🟢" : vix_regime == 3 ? "🔴" : "⚪"

term_spread = valid_data ? (vx2 - vx1) : 0.0
contango_pct = valid_data and vx1 != 0 ? ((vx2 / vx1) - 1) * 100 : 0.0

// VIX/VX1 Basis（现货溢价）- 恐慌领先指标
vix_basis = valid_data and vx1 != 0 ? ((vix / vx1) - 1) * 100 : 0.0

// v7.9: Warmup 检查 - 确保百分位计算有足够数据
has_sufficient_data = bar_index >= adapt_lookback

// 自适应阈值计算（带 warmup 保护）
// v7.10: ta.percentile_linear_interpolation 必须每根K线调用，先算再选
vix_basis_pct_raw_high = ta.percentile_linear_interpolation(vix_basis, adapt_lookback, 90)
vix_basis_pct_raw_low  = ta.percentile_linear_interpolation(vix_basis, adapt_lookback, 10)
pcr_pct_raw_high       = ta.percentile_linear_interpolation(pcr, adapt_lookback, 90)
pcr_pct_raw_low        = ta.percentile_linear_interpolation(pcr, adapt_lookback, 10)

vix_basis_pct_high = has_sufficient_data ? vix_basis_pct_raw_high : 5.0
vix_basis_pct_low  = has_sufficient_data ? vix_basis_pct_raw_low  : -3.0
pcr_pct_high       = has_sufficient_data ? pcr_pct_raw_high       : 1.20
pcr_pct_low        = has_sufficient_data ? pcr_pct_raw_low        : 0.70

// 根据设置选择阈值模式
is_basis_panic = use_adaptive_thresholds ? (vix_basis > vix_basis_pct_high) : (vix_basis > 5)
is_basis_calm  = use_adaptive_thresholds ? (vix_basis < vix_basis_pct_low) : (vix_basis < -3)
is_pcr_panic = not na(pcr) and (use_adaptive_thresholds ? (pcr > pcr_pct_high) : (pcr > 1.20))
is_pcr_calm  = not na(pcr) and (use_adaptive_thresholds ? (pcr < pcr_pct_low) : (pcr < 0.70))

// v7.13 (M4): 滞回带防止 VIX 在阈值附近来回切换 Z 回溯期；无 var 状态，可在 security 上下文中独立实例化
// Hysteresis stops Z-lookback flip-flop near vol_thresh; stateless self-referential form instantiates per security context.
// band=0 时每根K线必然落入 above/below 之一（数据无效也归入 below），与 v7.12 逐K线完全一致
// With band=0 every bar resolves to above/below (invalid data falls into below), reproducing v7.12 bar-for-bar.
vol_above_hi = valid_data and vix > vol_thresh + vol_hysteresis
vol_below_lo = not valid_data or vix <= vol_thresh - vol_hysteresis
float is_high_vol_state = na
is_high_vol_state := vol_above_hi ? 1.0 : vol_below_lo ? 0.0 : nz(is_high_vol_state[1], 0.0)
is_high_vol = is_high_vol_state > 0.5
lookback    = use_adaptive ? (is_high_vol ? len_high : len_low) : len_low
avg   = ta.sma(term_spread, lookback)
stdev = ta.stdev(term_spread, lookback)
raw_z = (valid_data and stdev != 0) ? (term_spread - avg) / stdev : 0.0
z_chart = ta.ema(raw_z, smooth_dyn)

// Z-Score 动量（变化率）- 带中性区域
z_roc = z_chart - z_chart[momentum_bars]
z_momentum_bullish_chart = z_roc < -z_momentum_neutral_zone  // Z 在下降超过阈值（恐慌加剧）
z_momentum_bearish_chart = z_roc > z_momentum_neutral_zone   // Z 在上升超过阈值（贪婪加剧）
z_momentum_flat = math.abs(z_roc) <= z_momentum_neutral_zone  // 中性区域

// 周线 MTF 确认 (v7.7: 统一 lookahead 策略)
// v7.10: 使用 SPX 日历对齐（VIX 为 SPX 衍生品），确保跨图表一致性
z_weekly = request.security("SP:SPX", "W", z_chart, lookahead=lookahead_setting, ignore_invalid_symbol=true)
// v7.9: 当 MTF 确认开启但周线数据不可用时，不允许信号通过（更保守）
is_weekly_buy_aligned_chart = not na(z_weekly) ? z_weekly < -thresh_mid : not use_mtf_confirm
is_weekly_sell_aligned_chart = not na(z_weekly) ? z_weekly > thresh_mid : not use_mtf_confirm
// v7.13: confirmed 专用周线源 — [1] + 固定 lookahead_on，历史与实时一致返回上一已完成周（外层请求与实盘安全模式开关解耦）
// Confirmed-only weekly source: [1] + hardcoded lookahead_on returns the last COMPLETED week identically on historical and realtime bars (outer request decoupled from the Trading Safe Mode toggle).
// 注意: z_chart 的内层日线请求在周线上下文中是 D-in-W（低周期请求），仍随安全模式开关采样——开=取每周最后一个日线值(周五)，关=取第一个(周一)
// Note: z_chart's inner daily requests become D-in-W (lower-TF) inside the weekly context and still follow the toggle — Safe Mode ON samples each completed week's LAST daily bar (Friday), OFF its FIRST (Monday).
z_weekly_confirmed = request.security("SP:SPX", "W", z_chart[1], lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
is_weekly_buy_aligned_confirmed = not na(z_weekly_confirmed) ? z_weekly_confirmed < -thresh_mid : not use_mtf_confirm
is_weekly_sell_aligned_confirmed = not na(z_weekly_confirmed) ? z_weekly_confirmed > thresh_mid : not use_mtf_confirm

// Smart SKEW - 优化：支持百分位数模式
skew_avg   = ta.sma(skew, skew_len)
skew_stdev = ta.stdev(skew, skew_len)
skew_z     = skew_stdev != 0 ? (skew - skew_avg) / skew_stdev : 0.0

// SKEW 百分位数计算（更自适应）
skew_pct_high = ta.percentile_linear_interpolation(skew, 252, 90)
skew_pct_low  = ta.percentile_linear_interpolation(skew, 252, 10)

skew_trig_high = sens_mode == "High (Scalping)" ? 1.5 : 1.8 

// 根据模式选择 SKEW 判断逻辑
is_skew_high = skew_mode == "Relative (Z-Score)" ? (skew_z > skew_trig_high) : 
               skew_mode == "Percentile (Adaptive)" ? (skew > skew_pct_high) : 
               (skew > 145)
is_skew_low  = skew_mode == "Relative (Z-Score)" ? (skew_z < -1.5) : 
               skew_mode == "Percentile (Adaptive)" ? (skew < skew_pct_low) : 
               (skew < 110)
scaled_skew = not na(skew) ? (skew - 100) / 10 : na

// VVIX 自适应阈值计算 (v7.1 新增)
vvix_avg = ta.sma(vvix, 252)
vvix_stdev = ta.stdev(vvix, 252)
vvix_z = not na(vvix) and vvix_stdev != 0 ? (vvix - vvix_avg) / vvix_stdev : 0.0
vvix_pct_high = ta.percentile_linear_interpolation(vvix, 252, 90)
vvix_pct_low  = ta.percentile_linear_interpolation(vvix, 252, 10)

// VVIX 判断 - 支持三种模式
vvix_panic_check = vvix_threshold_mode == "Z-Score" ? vvix_z > vvix_z_thresh : vvix_threshold_mode == "Percentile" ? vvix > vvix_pct_high : vvix > vvix_panic_thresh
vvix_calm_check = vvix_threshold_mode == "Z-Score" ? vvix_z < -vvix_z_thresh : vvix_threshold_mode == "Percentile" ? vvix < vvix_pct_low : vvix < vvix_calm_thresh
is_vvix_panic = use_vvix and not na(vvix) and vvix_panic_check
is_vvix_calm = use_vvix and not na(vvix) and vvix_calm_check

// Smart Volume - 使用滚动窗口最大值
vol_ma = ta.sma(vx1_vol, vol_avg_len)
vol_max_rolling = ta.highest(vx1_vol, 252)  // 滚动252日最大值
is_vol_spike  = vx1_vol >= vol_ma * 2.5 
is_vol_high   = vx1_vol >= vol_ma * 1.5 
col_vol = is_vol_spike ? color.new(color.yellow, 30) : is_vol_high ? color.new(color.aqua, 60) : color.new(color.gray, 90)
vol_visual_boost = is_vol_spike ? 1.2 : 1.0 
has_core_panic_confirmation_chart = contango_pct < 0 or is_basis_panic or is_pcr_panic or is_vol_spike or (use_vvix and is_vvix_panic)
has_core_euphoria_confirmation_chart = is_basis_calm or is_pcr_calm or is_skew_high or contango_pct > 10 or (use_vvix and is_vvix_calm)
sell_requires_core_confirmation = sell_strictness == "High Win-Rate"

// ========== 4. AI 信号算法 (Enhanced v7.0 - 模块化) ==========

// 使用模块化评分函数
// v7.10: Score 为纯 VIX 结构客观评分，不再包含趋势惩罚
// 趋势过滤仅影响信号展示（BUY DIP → NO TRADE），不改变 Score
float score_core_chart = calc_z_score_points(z_chart, thresh_mid, thresh_strong) +
         calc_contango_points(contango_pct) +
         calc_basis_points(is_basis_panic, is_basis_calm) +
         calc_skew_points(is_skew_high, is_skew_low) +
         calc_pcr_points(is_pcr_panic, is_pcr_calm) +
         calc_vvix_points(is_vvix_panic, is_vvix_calm, use_vvix) +
         (is_vol_spike and z_chart < -thresh_mid ? 1 : 0) +
         (use_momentum_confirm and z_chart < -thresh_mid and z_momentum_bullish_chart ? 1 : 0) +
         (use_momentum_confirm and z_chart > thresh_mid and z_momentum_bearish_chart ? -1 : 0)
// v7.13: MTF 项拆分为 live / confirmed 两套：live 跟随实盘安全模式，confirmed 使用固定 lookahead 的已完成周线源
// MTF terms split: live variant follows Trading Safe Mode; confirmed variant uses the hardcoded-lookahead completed-week source (toggle-independent).
mtf_buy_pts_live = use_mtf_confirm and z_chart < -thresh_mid and is_weekly_buy_aligned_chart ? 1 : 0
mtf_sell_pts_live = use_mtf_confirm and z_chart > thresh_mid and is_weekly_sell_aligned_chart ? -1 : 0
mtf_buy_pts_confirmed = use_mtf_confirm and z_chart < -thresh_mid and is_weekly_buy_aligned_confirmed ? 1 : 0
mtf_sell_pts_confirmed = use_mtf_confirm and z_chart > thresh_mid and is_weekly_sell_aligned_confirmed ? -1 : 0
float score_chart = score_core_chart + mtf_buy_pts_live + mtf_sell_pts_live
float score_confirmed_chart = score_core_chart + mtf_buy_pts_confirmed + mtf_sell_pts_confirmed

// ========== 4.1 日线上下文评分源 (v7.13 Daily-Context Score Sourcing) ==========
// H2: Score 及其门控因子在 SP:SPX 日线上下文统一计算：盘中与 1D 图得到一致的日线数值；周线/月线图按每根K线采样一个日线值（默认安全模式取最后一个日线值）
// H2: Score and its gates are evaluated in the SP:SPX daily context — intraday and 1D charts see the 1D values; >1D charts sample one daily value per chart bar (last daily value in default safe mode).
// lookahead 跟随实盘安全模式 lookahead follows Trading Safe Mode:
// ON = lookahead_off: 历史K线=已完成交易日, 实时K线=发展中的当日值 historical = completed days, realtime = developing day
// OFF = lookahead_on: 历史盘中K线=当日最终值(重绘语义与 v7.12 一致, 数值已改为日线口径) historical intraday = same-day final values (repaint semantics as in v7.12; values are now daily-context)
[score, z, z_momentum_bullish, z_momentum_bearish, has_core_panic_confirmation, has_core_euphoria_confirmation, is_weekly_buy_aligned, is_weekly_sell_aligned] = request.security("SP:SPX", "D", [score_chart, z_chart, z_momentum_bullish_chart, z_momentum_bearish_chart, has_core_panic_confirmation_chart, has_core_euphoria_confirmation_chart, is_weekly_buy_aligned_chart, is_weekly_sell_aligned_chart], lookahead=lookahead_setting, ignore_invalid_symbol=true)

// H1: confirmed 锚点 — 元素逐项 [1] 偏移 + 固定 lookahead_on，在历史与实时K线上一致地返回上一已完成结构日
// 链路级解耦：confirmed 链内的 D-in-D 内层请求对开关不敏感（前提是符号遵循美股日历；24小时日历的自定义 VIX/PCR/趋势符号会让快照在开关间偏移一天），故默认配置下 confirmed 路径不随安全模式开关变化
// H1: confirmed anchor — per-element [1] offset + hardcoded lookahead_on returns the last COMPLETED structure day identically on historical and realtime bars (canonical non-repainting HTF pattern).
// Chain-level decoupling: the inner D-in-D requests in the confirmed chain are toggle-inert (assuming US-calendar symbols; 24h-calendar custom VIX/PCR/trend symbols shift the snapshot one day between toggle states), so in the default config the confirmed path is independent of the Trading Safe Mode toggle.
// 例外: use_mtf_confirm 开启时，周线 MTF 腿（z_weekly_confirmed）在周线上下文内的 D-in-W 日线采样仍随开关变化（开=周五样本，关=周一样本），confirmed 评分可能相差 ±1——建议保持安全模式开启
// Exception: with use_mtf_confirm ON, the weekly MTF leg (z_weekly_confirmed) samples its inner daily data D-in-W and still follows the toggle (ON = Friday sample, OFF = Monday sample), which can shift the confirmed score by +/-1 — keep Safe Mode ON.
[confirmed_day_id_d, confirmed_score_d, confirmed_z_d, confirmed_vix_d, confirmed_skew_d, confirmed_spx_bull_d, confirmed_ndx_bull_d, confirmed_rut_bull_d, confirmed_manual_bull_d, confirmed_z_mom_bull_d, confirmed_z_mom_bear_d, confirmed_core_panic_d, confirmed_core_euphoria_d, confirmed_weekly_buy_d, confirmed_weekly_sell_d] = request.security("SP:SPX", "D", [day_id_src[1], score_confirmed_chart[1], z_chart[1], vix[1], skew[1], is_spx_bull[1], is_ndx_bull[1], is_rut_bull[1], is_manual_bull[1], z_momentum_bullish_chart[1], z_momentum_bearish_chart[1], has_core_panic_confirmation_chart[1], has_core_euphoria_confirmation_chart[1], is_weekly_buy_aligned_confirmed[1], is_weekly_sell_aligned_confirmed[1]], lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)

// 盘中锚定到已完成结构日；日线及以上保持图表自身日期，逐K线快照+收盘发送（保留 v7.12 的 1D 行为）
// Intraday anchors to the completed structure day; 1D+ keeps the chart's own date so the v7.12 same-bar-close semantics are preserved.
confirmed_structure_day_id = timeframe.isintraday ? math.round(confirmed_day_id_d) : day_id_src

// ========== 5. 三级买入信号 (v7.0 新增, v7.3 优化) ==========
// 基于 Score 评级的信号触发（首次进入该评级时触发）
is_crash_buy_raw = score >= 6 and score[1] < 6
is_strong_buy_raw = score >= 5 and score < 6 and score[1] < 5
is_buy_dip_raw = score >= min_score_buy and score < 5 and score[1] < min_score_buy

// 卖出信号原始判断
is_euphoria_sell_raw = score <= -6 and score[1] > -6
is_strong_sell_raw = score <= -5 and score > -6 and score[1] > -5
is_sell_hedge_raw = score <= -2 and score > -5 and score[1] > -2

// 信号确认机制 (v7.1 新增) - 仅在 K 线确认后触发
is_crash_buy = use_confirmed_signals ? (is_crash_buy_raw and barstate.isconfirmed) : is_crash_buy_raw
is_strong_buy = use_confirmed_signals ? (is_strong_buy_raw and barstate.isconfirmed) : is_strong_buy_raw
is_buy_dip_base = use_confirmed_signals ? (is_buy_dip_raw and barstate.isconfirmed) : is_buy_dip_raw
is_euphoria_sell = use_confirmed_signals ? (is_euphoria_sell_raw and barstate.isconfirmed) : is_euphoria_sell_raw
is_strong_sell_base = use_confirmed_signals ? (is_strong_sell_raw and barstate.isconfirmed) : is_strong_sell_raw
is_sell_hedge_base = use_confirmed_signals ? (is_sell_hedge_raw and barstate.isconfirmed) : is_sell_hedge_raw

// ===== v7.3 新增：信号冷却追踪变量 =====
var int last_sell_hedge_bar = 0
var int last_buy_dip_bar = 0

// ===== v7.3 新增：增强版 sell_hedge/buy_dip 信号过滤 =====
// sell_hedge 增强条件：
// 1. VIX Regime 不是 LOW VOL（低波动期不需要对冲）
// 2. Z Momentum 上升（贪婪加剧）或 Weekly 卖出对齐
// 3. 满足信号冷却间隔
is_sell_hedge_momentum_ok = z_momentum_bearish or (use_mtf_confirm and is_weekly_sell_aligned) or not use_momentum_confirm
is_sell_hedge_cooldown_ok = bar_index - last_sell_hedge_bar > signal_display_cooldown
sell_core_ok = not sell_requires_core_confirmation or has_core_euphoria_confirmation
is_sell_hedge = is_sell_hedge_base and vix_regime != 1 and is_sell_hedge_momentum_ok and is_sell_hedge_cooldown_ok and sell_core_ok

// buy_dip 增强条件：
// 1. VIX Regime 不是 HIGH VOL（高波动期等待更强信号）
// 2. Z Momentum 下降（恐慌加剧）或 Weekly 买入对齐
// 3. 满足信号冷却间隔
is_buy_dip_momentum_ok = z_momentum_bullish or (use_mtf_confirm and is_weekly_buy_aligned) or not use_momentum_confirm
is_buy_dip_cooldown_ok = bar_index - last_buy_dip_bar > signal_display_cooldown
is_buy_dip = is_buy_dip_base and vix_regime != 3 and is_buy_dip_momentum_ok and is_buy_dip_cooldown_ok

// 更新冷却追踪
if is_sell_hedge
    last_sell_hedge_bar := bar_index
if is_buy_dip
    last_buy_dip_bar := bar_index

// 趋势过滤
is_signal_allowed = use_trend_filter ? is_bull_market : true

// 最终信号（用于 Alert 和图表标签）
final_crash_buy = is_crash_buy  // CRASH BUY 不受趋势过滤限制
final_strong_buy = is_strong_buy  // STRONG BUY 不受趋势过滤限制
final_buy_dip = is_buy_dip and is_signal_allowed and z < -thresh_mid and has_core_panic_confirmation  // BUY DIP 需核心恐慌确认
final_euphoria_sell = is_euphoria_sell  // EUPHORIA 保持最强极端顶部，不加额外核心过滤
final_strong_sell = is_strong_sell_base and sell_core_ok
final_sell_hedge = is_sell_hedge

final_buy_signal = final_crash_buy or final_strong_buy or final_buy_dip
final_sell_signal = final_euphoria_sell or final_strong_sell or final_sell_hedge

// 信号等级函数 (优先级越高值越大)
// Buy: 0=无, 1=BUY_DIP, 2=STRONG_BUY, 3=CRASH_BUY
// Sell: 0=无, 1=SELL_HEDGE, 2=STRONG_SELL, 3=EUPHORIA_SELL
f_buy_signal_level(_crash, _strong, _dip) =>
    _crash ? 3 : _strong ? 2 : _dip ? 1 : 0
f_sell_signal_level(_euphoria, _strong, _hedge) =>
    _euphoria ? 3 : _strong ? 2 : _hedge ? 1 : 0

// ========== 5.1 Alert Timing Signals (v7.11) ==========
// Preview alerts keep the earliest-possible behavior.
preview_crash_buy = final_crash_buy
preview_strong_buy = final_strong_buy
preview_buy_dip = final_buy_dip
preview_euphoria_sell = final_euphoria_sell
preview_strong_sell = final_strong_sell
preview_sell_hedge = final_sell_hedge

// Confirmed alerts snapshot one completed structure day and emit once on the next regular-session opportunity.
new_confirmed_structure_day = not na(confirmed_structure_day_id) and (na(confirmed_structure_day_id[1]) or confirmed_structure_day_id != confirmed_structure_day_id[1])
has_new_chart_day = year != year[1] or month != month[1] or dayofmonth != dayofmonth[1]
chart_day_id = day_id_src

var float last_confirmed_structure_score = na
var int pending_confirmed_buy_level = 0
var int pending_confirmed_sell_level = 0
var int pending_confirmed_structure_day = 0
var float pending_confirmed_score = na
var float pending_confirmed_z = na
var float pending_confirmed_vix = na
var float pending_confirmed_skew = na
var string pending_confirmed_vix_regime_txt = ""
var string pending_confirmed_trend_status_txt = ""
// confirmed 模式下同一结构日只发一次；用 varip 避免实时bar回滚导致重复触发。
varip int emitted_confirmed_buy_day = 0
varip int emitted_confirmed_sell_day = 0

// v7.13: confirmed 数据源 — 盘中取已完成结构日（tuple），日线及以上沿用当根K线实时值（v7.12 语义）
// Confirmed feed: intraday uses the completed structure day tuple; 1D+ keeps the live same-bar values (v7.12 semantics).
confirmed_feed_score = timeframe.isintraday ? confirmed_score_d : score
confirmed_feed_z = timeframe.isintraday ? confirmed_z_d : z
confirmed_feed_vix = timeframe.isintraday ? confirmed_vix_d : vix
confirmed_feed_skew = timeframe.isintraday ? confirmed_skew_d : skew
confirmed_feed_vix_regime = confirmed_feed_vix < vix_low_thresh ? 1 : confirmed_feed_vix > vix_high_thresh ? 3 : 2
confirmed_feed_vix_regime_txt = confirmed_feed_vix_regime == 1 ? "LOW" : confirmed_feed_vix_regime == 3 ? "HIGH" : "NORM"
confirmed_trend_txt_d = (confirmed_spx_bull_d ? "🟢" : "🔴") + "SPX " + (confirmed_ndx_bull_d ? "🟢" : "🔴") + "NDX " + (confirmed_rut_bull_d ? "🟢" : "🔴") + "RUT"
confirmed_feed_trend_txt = timeframe.isintraday ? confirmed_trend_txt_d : trend_status_txt
// v7.13: confirmed 趋势门控同样取自已完成结构日快照（与告警趋势文本同源），不读取实时趋势，保证重载一致并与安全模式开关解耦
// Confirmed trend gate also comes from the completed-structure-day snapshot (same source as the alert trend text): no live trend read, reload-stable, Trading Safe Mode independent.
// 注意: is_primary_bull 不能直接放入 tuple（syminfo.ticker 在 security 上下文中解析为 SPX，会破坏自动识别），故在图表层用已快照的分指数布尔值重建
// Note: is_primary_bull must NOT go into the tuple (syminfo.ticker resolves to SPX inside the security context, breaking auto-detect); rebuild at chart level from the snapshotted per-index bools.
confirmed_auto_bull_d = is_russell_chart ? confirmed_rut_bull_d : is_nasdaq_chart ? confirmed_ndx_bull_d : confirmed_spx_bull_d
confirmed_primary_bull_d = auto_detect_index ? confirmed_auto_bull_d : confirmed_manual_bull_d
confirmed_signal_allowed_d = use_trend_filter ? confirmed_primary_bull_d : true
confirmed_feed_signal_allowed = timeframe.isintraday ? confirmed_signal_allowed_d : is_signal_allowed
confirmed_d_momentum_buy_ok = confirmed_z_mom_bull_d or (use_mtf_confirm and confirmed_weekly_buy_d) or not use_momentum_confirm
confirmed_d_momentum_sell_ok = confirmed_z_mom_bear_d or (use_mtf_confirm and confirmed_weekly_sell_d) or not use_momentum_confirm
confirmed_feed_momentum_buy_ok = timeframe.isintraday ? confirmed_d_momentum_buy_ok : is_buy_dip_momentum_ok
confirmed_feed_momentum_sell_ok = timeframe.isintraday ? confirmed_d_momentum_sell_ok : is_sell_hedge_momentum_ok
confirmed_feed_core_panic = timeframe.isintraday ? confirmed_core_panic_d : has_core_panic_confirmation
confirmed_feed_core_euphoria = timeframe.isintraday ? confirmed_core_euphoria_d : has_core_euphoria_confirmation

if new_confirmed_structure_day
    confirmed_prev_score = last_confirmed_structure_score
    confirmed_has_prev = not na(confirmed_prev_score)
    confirmed_sell_core_ok = not sell_requires_core_confirmation or confirmed_feed_core_euphoria
    confirmed_crash_buy = confirmed_has_prev and confirmed_feed_score >= 6 and confirmed_prev_score < 6
    confirmed_strong_buy = confirmed_has_prev and confirmed_feed_score >= 5 and confirmed_feed_score < 6 and confirmed_prev_score < 5
    confirmed_buy_dip = confirmed_has_prev and confirmed_feed_score >= min_score_buy and confirmed_feed_score < 5 and confirmed_prev_score < min_score_buy and confirmed_feed_vix_regime != 3 and confirmed_feed_momentum_buy_ok and confirmed_feed_signal_allowed and confirmed_feed_z < -thresh_mid and confirmed_feed_core_panic
    confirmed_euphoria_sell = confirmed_has_prev and confirmed_feed_score <= -6 and confirmed_prev_score > -6
    confirmed_strong_sell = confirmed_has_prev and confirmed_feed_score <= -5 and confirmed_feed_score > -6 and confirmed_prev_score > -5 and confirmed_sell_core_ok
    confirmed_sell_hedge = confirmed_has_prev and confirmed_feed_score <= -2 and confirmed_feed_score > -5 and confirmed_prev_score > -2 and confirmed_feed_vix_regime != 1 and confirmed_feed_momentum_sell_ok and confirmed_sell_core_ok
    pending_confirmed_buy_level := f_buy_signal_level(confirmed_crash_buy, confirmed_strong_buy, confirmed_buy_dip)
    pending_confirmed_sell_level := f_sell_signal_level(confirmed_euphoria_sell, confirmed_strong_sell, confirmed_sell_hedge)
    pending_confirmed_structure_day := confirmed_structure_day_id
    pending_confirmed_score := confirmed_feed_score
    pending_confirmed_z := confirmed_feed_z
    pending_confirmed_vix := confirmed_feed_vix
    pending_confirmed_skew := confirmed_feed_skew
    pending_confirmed_vix_regime_txt := confirmed_feed_vix_regime_txt
    pending_confirmed_trend_status_txt := confirmed_feed_trend_txt
    last_confirmed_structure_score := confirmed_feed_score

is_alert_preview_mode = alert_timing_mode == "Preview / Earliest Possible"
is_regular_session_only = after_hours_alert_policy == "Regular Session Only"
is_hybrid_alert_mode = is_alert_preview_mode and vix_timeframe == "Chart"
alert_mode_tag = is_alert_preview_mode ? "[PREVIEW]" : "[CONFIRMED]"
alert_mode_panel = is_alert_preview_mode ? (is_hybrid_alert_mode ? "PREVIEW*" : "PREVIEW") : "CONFIRMED"
alert_mode_desc = is_alert_preview_mode ? (is_hybrid_alert_mode ? "Hybrid preview" : "Preview") : "Confirmed"
regular_session_bar = not timeframe.isintraday or session.ismarket
// 非常规时段（盘前/盘后）统一按 extended 处理，避免不同品种会话定义差异导致漏拦截。
extended_preview_bar = is_alert_preview_mode and timeframe.isintraday and not session.ismarket
allow_alert_now = not is_regular_session_only or regular_session_bar
confirmed_emit_now = timeframe.isintraday ? (regular_session_bar and (not new_confirmed_structure_day or has_new_chart_day)) : barstate.isconfirmed

// ========== 6. 信号统计 (v7.0 新增, v7.7 改为滚动窗口) ==========
// v7.7: 使用 math.sum() 滚动窗口统计，替代累积计数
// 这确保统计始终反映"最近 N 年"的数据，不会随时间漂移
is_stats_daily_chart = timeframe.isdaily and timeframe.multiplier == 1
stats_lookback_bars = stats_lookback_years * 252
stats_max_hold_bars = math.max(crash_return_bars, math.max(strong_return_bars, dip_return_bars))
stats_ready = is_stats_daily_chart and bar_index >= stats_lookback_bars + stats_max_hold_bars

// 统计只使用 1D 图表上的 confirmed 最终信号，避免 intraday 展开的 HTF 数据扭曲胜率。
stats_crash_buy = final_crash_buy and barstate.isconfirmed
stats_strong_buy = final_strong_buy and barstate.isconfirmed
stats_buy_dip = final_buy_dip and barstate.isconfirmed
stats_euphoria_sell = final_euphoria_sell and barstate.isconfirmed
stats_strong_sell = final_strong_sell and barstate.isconfirmed
stats_sell_hedge = final_sell_hedge and barstate.isconfirmed

// v7.10: 统计收益使用对应指数（Auto-Detect: QQQ→NDX, IWM→RUT, 其他→SPX）
// 确保过滤逻辑和统计口径一致
auto_ref_close = is_russell_chart ? rut_close : is_nasdaq_chart ? ndx_close : spx_close
ref_close = auto_detect_index ? auto_ref_close : (not na(manual_close) ? manual_close : spx_close)

// 回报计算：信号发出后 N 天的收益
crash_ref_return = not na(ref_close) and not na(ref_close[crash_return_bars]) ? (ref_close - ref_close[crash_return_bars]) / ref_close[crash_return_bars] * 100 : 0.0
strong_ref_return = not na(ref_close) and not na(ref_close[strong_return_bars]) ? (ref_close - ref_close[strong_return_bars]) / ref_close[strong_return_bars] * 100 : 0.0
dip_ref_return = not na(ref_close) and not na(ref_close[dip_return_bars]) ? (ref_close - ref_close[dip_return_bars]) / ref_close[dip_return_bars] * 100 : 0.0

// v7.7: 滚动窗口收益统计
// 仅当 N 天前有信号时，才计入当前收益
crash_eval_num = stats_crash_buy[crash_return_bars] ? 1 : 0
strong_eval_num = stats_strong_buy[strong_return_bars] ? 1 : 0
dip_eval_num = stats_buy_dip[dip_return_bars] ? 1 : 0
euphoria_eval_num = stats_euphoria_sell[crash_return_bars] ? 1 : 0
strong_sell_eval_num = stats_strong_sell[strong_return_bars] ? 1 : 0
sell_hedge_eval_num = stats_sell_hedge[dip_return_bars] ? 1 : 0
crash_win_num = stats_crash_buy[crash_return_bars] and crash_ref_return > 0 ? 1 : 0
strong_win_num = stats_strong_buy[strong_return_bars] and strong_ref_return > 0 ? 1 : 0
dip_win_num = stats_buy_dip[dip_return_bars] and dip_ref_return > 0 ? 1 : 0
euphoria_win_num = stats_euphoria_sell[crash_return_bars] and crash_ref_return <= 0 ? 1 : 0
strong_sell_win_num = stats_strong_sell[strong_return_bars] and strong_ref_return <= 0 ? 1 : 0
sell_hedge_win_num = stats_sell_hedge[dip_return_bars] and dip_ref_return <= 0 ? 1 : 0
crash_return_contrib = stats_crash_buy[crash_return_bars] ? crash_ref_return : 0.0
strong_return_contrib = stats_strong_buy[strong_return_bars] ? strong_ref_return : 0.0
dip_return_contrib = stats_buy_dip[dip_return_bars] ? dip_ref_return : 0.0
euphoria_return_contrib = stats_euphoria_sell[crash_return_bars] ? crash_ref_return : 0.0
strong_sell_return_contrib = stats_strong_sell[strong_return_bars] ? strong_ref_return : 0.0
sell_hedge_return_contrib = stats_sell_hedge[dip_return_bars] ? dip_ref_return : 0.0

// 滚动窗口内的收益总和
crash_buy_return_sum = math.sum(crash_return_contrib, stats_lookback_bars)
strong_buy_return_sum = math.sum(strong_return_contrib, stats_lookback_bars)
buy_dip_return_sum = math.sum(dip_return_contrib, stats_lookback_bars)
euphoria_sell_return_sum = math.sum(euphoria_return_contrib, stats_lookback_bars)
strong_sell_return_sum = math.sum(strong_sell_return_contrib, stats_lookback_bars)
sell_hedge_return_sum = math.sum(sell_hedge_return_contrib, stats_lookback_bars)

// 滚动窗口内只统计已经走完持有周期的样本。
crash_buy_evaluated_count = math.round(math.sum(crash_eval_num, stats_lookback_bars))
strong_buy_evaluated_count = math.round(math.sum(strong_eval_num, stats_lookback_bars))
buy_dip_evaluated_count = math.round(math.sum(dip_eval_num, stats_lookback_bars))
euphoria_sell_evaluated_count = math.round(math.sum(euphoria_eval_num, stats_lookback_bars))
strong_sell_evaluated_count = math.round(math.sum(strong_sell_eval_num, stats_lookback_bars))
sell_hedge_evaluated_count = math.round(math.sum(sell_hedge_eval_num, stats_lookback_bars))
crash_buy_win_count = math.round(math.sum(crash_win_num, stats_lookback_bars))
strong_buy_win_count = math.round(math.sum(strong_win_num, stats_lookback_bars))
buy_dip_win_count = math.round(math.sum(dip_win_num, stats_lookback_bars))
euphoria_sell_win_count = math.round(math.sum(euphoria_win_num, stats_lookback_bars))
strong_sell_win_count = math.round(math.sum(strong_sell_win_num, stats_lookback_bars))
sell_hedge_win_count = math.round(math.sum(sell_hedge_win_num, stats_lookback_bars))

// 计算平均收益
crash_buy_avg_return = crash_buy_evaluated_count > 0 ? crash_buy_return_sum / crash_buy_evaluated_count : 0.0
strong_buy_avg_return = strong_buy_evaluated_count > 0 ? strong_buy_return_sum / strong_buy_evaluated_count : 0.0
buy_dip_avg_return = buy_dip_evaluated_count > 0 ? buy_dip_return_sum / buy_dip_evaluated_count : 0.0
euphoria_sell_avg_return = euphoria_sell_evaluated_count > 0 ? euphoria_sell_return_sum / euphoria_sell_evaluated_count : 0.0
strong_sell_avg_return = strong_sell_evaluated_count > 0 ? strong_sell_return_sum / strong_sell_evaluated_count : 0.0
sell_hedge_avg_return = sell_hedge_evaluated_count > 0 ? sell_hedge_return_sum / sell_hedge_evaluated_count : 0.0
crash_buy_win_rate = crash_buy_evaluated_count > 0 ? crash_buy_win_count * 100.0 / crash_buy_evaluated_count : 0.0
strong_buy_win_rate = strong_buy_evaluated_count > 0 ? strong_buy_win_count * 100.0 / strong_buy_evaluated_count : 0.0
buy_dip_win_rate = buy_dip_evaluated_count > 0 ? buy_dip_win_count * 100.0 / buy_dip_evaluated_count : 0.0
euphoria_sell_win_rate = euphoria_sell_evaluated_count > 0 ? euphoria_sell_win_count * 100.0 / euphoria_sell_evaluated_count : 0.0
strong_sell_win_rate = strong_sell_evaluated_count > 0 ? strong_sell_win_count * 100.0 / strong_sell_evaluated_count : 0.0
sell_hedge_win_rate = sell_hedge_evaluated_count > 0 ? sell_hedge_win_count * 100.0 / sell_hedge_evaluated_count : 0.0

// 最终信号翻译
signal_txt = ""
signal_col = color.gray
signal_emoji = ""

if score >= 6
    signal_txt := "🚨 CRASH BUY"
    signal_col := color.new(#00FF00, 0)
    signal_emoji := "🚨"
else if score >= 5
    signal_txt := "🟢 STRONG BUY"
    signal_col := color.green
    signal_emoji := "🟢"
else if score >= min_score_buy
    if vix_regime == 3
        signal_txt := "✋ WAIT (Vol)"
        signal_col := color.gray
        signal_emoji := "✋"
    else if use_momentum_confirm and not is_buy_dip_momentum_ok
        signal_txt := "✋ WAIT (Mom)"
        signal_col := color.gray
        signal_emoji := "✋"
    else if not has_core_panic_confirmation
        signal_txt := "✋ WAIT (Core)"
        signal_col := color.gray
        signal_emoji := "✋"
    else
        signal_txt := "🟡 BUY DIP"
        signal_col := color.lime
        signal_emoji := "🟡"
else if score <= -6
    signal_txt := "🔥 EUPHORIA"
    signal_col := color.new(#FF0000, 0)
    signal_emoji := "🔥"
else if score <= -5
    if sell_requires_core_confirmation and not has_core_euphoria_confirmation
        signal_txt := "✋ HOLD (Core)"
        signal_col := color.gray
        signal_emoji := "✋"
    else
        signal_txt := "🔴 STRONG SELL"
        signal_col := color.red
        signal_emoji := "🔴"
else if score <= -2
    if vix_regime == 1
        signal_txt := "☕ HOLD (Vol)"
        signal_col := color.gray
        signal_emoji := "☕"
    else if use_momentum_confirm and not is_sell_hedge_momentum_ok
        signal_txt := "✋ HOLD (Mom)"
        signal_col := color.gray
        signal_emoji := "✋"
    else if sell_requires_core_confirmation and not has_core_euphoria_confirmation
        signal_txt := "✋ HOLD (Core)"
        signal_col := color.gray
        signal_emoji := "✋"
    else
        signal_txt := "🟠 SELL/HEDGE"
        signal_col := color.orange
        signal_emoji := "🟠"
else
    signal_txt := "⏸ NEUTRAL"
    signal_col := color.gray
    signal_emoji := "⏸"

// 熊市特殊提示
if use_trend_filter and not is_bull_market and score >= min_score_buy and score < 5
    signal_txt := "🚫 NO TRADE"
    signal_col := color.gray
    signal_emoji := "🚫"

// ========== 7. 绘图 ==========
bgcolor(contango_pct > 0 ? color.new(color.green, 95) : color.new(color.red, 92))

col_z = z >= 0 ? color.from_gradient(z, 0, 3, color.new(color.blue, 40), color.new(color.blue, 10)) : 
                 color.from_gradient(z, -3, 0, color.new(color.red, 10), color.new(color.orange, 40))

plot(show_z ? z : na, color=col_z, title="Term Struct Z", linewidth=2)
plot(show_skew ? scaled_skew : na, color=color.new(color.fuchsia, 40), title="SKEW (Scaled)", linewidth=1)

hline(0, "Zero", color=color.gray, linestyle=hline.style_solid)
mid_hline_style = mid_line_style == "Solid" ? hline.style_solid : mid_line_style == "Dashed" ? hline.style_dashed : hline.style_dotted
hline(1, "+1 Mid", color=mid_line_color, linestyle=mid_hline_style)
hline(-1, "-1 Mid", color=mid_line_color, linestyle=mid_hline_style)
plot(thresh_strong, "Upper", color=color.new(color.gray, 50), style=plot.style_line)
plot(-thresh_strong, "Lower", color=color.new(color.gray, 50), style=plot.style_line)

// 使用滚动最大值的成交量可视化
scaled_vol = not na(vx1_vol) and vol_max_rolling > 0 ? ((vx1_vol * vol_visual_boost) / vol_max_rolling) * 1.8 - 3.8 : na
plot(show_volume ? scaled_vol : na, color=col_vol, title="Smart Volume", style=plot.style_columns, linewidth=2)

// ========== 8. 三级信号图表标签 (v7.0 新增) ==========
plotshape(final_crash_buy ? -thresh_strong - 0.3 : na, title="Crash Buy Signal", location=location.absolute, style=shape.labelup, color=color.new(#00FF00, 0), text="🚨", textcolor=color.white, size=size.small)
plotshape(final_strong_buy ? -thresh_strong - 0.3 : na, title="Strong Buy Signal", location=location.absolute, style=shape.labelup, color=color.new(color.green, 20), text="🟢", textcolor=color.white, size=size.tiny)
plotshape(final_buy_dip ? -thresh_strong - 0.3 : na, title="Buy Dip Signal", location=location.absolute, style=shape.labelup, color=color.new(color.lime, 20), text="🟡", textcolor=color.white, size=size.tiny)

plotshape(final_euphoria_sell ? thresh_strong + 0.3 : na, title="Euphoria Sell Signal", location=location.absolute, style=shape.labeldown, color=color.new(#FF0000, 0), text="🔥", textcolor=color.white, size=size.small)
plotshape(final_strong_sell ? thresh_strong + 0.3 : na, title="Strong Sell Signal", location=location.absolute, style=shape.labeldown, color=color.new(color.red, 20), text="🔴", textcolor=color.white, size=size.tiny)
plotshape(final_sell_hedge ? thresh_strong + 0.3 : na, title="Sell/Hedge Signal", location=location.absolute, style=shape.labeldown, color=color.new(color.orange, 20), text="🟠", textcolor=color.white, size=size.tiny)

// ========== 9. 重新设计的仪表盘 (v7.8) ==========
// 仪表盘位置转换函数
get_table_pos(pos) => pos == "Top Left" ? position.top_left : pos == "Bottom Right" ? position.bottom_right : pos == "Bottom Left" ? position.bottom_left : pos == "Top Center" ? position.top_center : pos == "Bottom Center" ? position.bottom_center : position.top_right

// v7.8: 深色主题配色
c_header = color.rgb(26, 26, 46)       // #1a1a2e 标题栏深蓝黑
c_group  = color.rgb(22, 33, 62)       // #16213e 分组标题次深蓝
c_row    = color.rgb(15, 15, 26, 30)   // #0f0f1a 普通行近黑(带透明)
c_buy_bg = color.rgb(10, 61, 46, 50)   // #0a3d2e 买入信号深绿背景
c_sell_bg = color.rgb(61, 10, 10, 50)  // #3d0a0a 卖出信号深红背景
c_label  = color.rgb(136, 136, 136)    // #888888 标签灰色
c_value  = color.rgb(255, 255, 255)    // #ffffff 数值白色

// 根据信号动态选择背景色
signal_bg = score >= 5 ? c_buy_bg : score <= -5 ? c_sell_bg : c_row

// v7.8: 仅在预览模式（非实盘安全模式）时显示重绘警告
is_preview_mode = not trading_safe_mode

// Mobile: 2行, Full: 16行
panel_rows = is_mobile ? 2 : 16
var table panel = table.new(get_table_pos(table_position), 2, panel_rows, border_width=0)

if show_table and barstate.islast
    if is_mobile
        // ═══════════════════════════════════════════════════════════════════
        // Mobile Mode: 极简2行
        // ═══════════════════════════════════════════════════════════════════
        // Row 0: 信号 + 分数
        table.cell(panel, 0, 0, signal_txt, bgcolor=signal_bg, text_color=signal_col, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 0, str.tostring(score, "+#.#;-#.#"), bgcolor=signal_bg, text_color=signal_col, text_halign=text.align_right, text_size=t_size)
        
        // Row 1: Alert Mode + VIX数值 (v7.11)
        vix_regime_str = alert_mode_panel
        vix_val_str = str.tostring(vix_display, "#.#") + (trading_safe_mode ? "ʳᵗ" : "")
        table.cell(panel, 0, 1, vix_regime_str, bgcolor=c_row, text_color=is_alert_preview_mode ? color.orange : color.aqua, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 1, vix_val_str, bgcolor=c_row, text_color=vix_regime_color, text_halign=text.align_right, text_size=t_size)
    else
        // ═══════════════════════════════════════════════════════════════════
        // Full Mode: 分组布局 + 进度条
        // ═══════════════════════════════════════════════════════════════════
        
        // --- Row 0: 标题栏 ---
        mode_tag = is_preview_mode ? "⚠️PREVIEW" : "🛡️SAFE"
        table.cell(panel, 0, 0, "VIX Term Pro", bgcolor=c_header, text_color=c_value, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 0, mode_tag, bgcolor=c_header, text_color=is_preview_mode ? color.orange : color.lime, text_halign=text.align_right, text_size=t_size)
        
        // --- Row 1: 信号（动态高亮背景）---
        table.cell(panel, 0, 1, signal_txt, bgcolor=signal_bg, text_color=signal_col, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 1, "", bgcolor=signal_bg, text_color=c_value, text_size=t_size)
        
        // --- Row 2: 进度条 + 分数 ---
        score_bar = f_score_bar(score)
        score_display = str.tostring(score, "+#.#;-#.#")
        bar_color = score >= 5 ? color.lime : score <= -5 ? color.red : color.silver
        table.cell(panel, 0, 2, score_bar, bgcolor=c_row, text_color=bar_color, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 2, score_display, bgcolor=c_row, text_color=bar_color, text_halign=text.align_right, text_size=t_size)
        
        // --- Row 3: MARKET 分组标题 ---
        table.cell(panel, 0, 3, "MARKET", bgcolor=c_group, text_color=c_label, text_halign=text.align_left, text_size=size.tiny)
        table.cell(panel, 1, 3, "", bgcolor=c_group, text_color=c_label, text_size=size.tiny)
        
        // --- Row 4: 三指数趋势 ---
        trend_compact = spx_emoji + " " + ndx_emoji + " " + rut_emoji
        table.cell(panel, 0, 4, trend_compact, bgcolor=c_row, text_color=trend_color, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 4, "SPX NDX RUT", bgcolor=c_row, text_color=c_label, text_halign=text.align_right, text_size=size.tiny)
        
        // --- Row 5: VIX Regime (v7.9: 使用实时VIX) ---
        vix_full_display = vix_regime_emoji + " " + vix_regime_txt
        vix_val_with_rt = str.tostring(vix_display, "#.#") + (trading_safe_mode ? " ʳᵗ" : "")
        table.cell(panel, 0, 5, vix_full_display, bgcolor=c_row, text_color=vix_regime_color, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 5, vix_val_with_rt, bgcolor=c_row, text_color=vix_regime_color, text_halign=text.align_right, text_size=t_size)
        
        // --- Row 6: Alert Mode ---
        table.cell(panel, 0, 6, "ALERT MODE", bgcolor=c_row, text_color=c_label, text_halign=text.align_left, text_size=size.tiny)
        table.cell(panel, 1, 6, alert_mode_panel, bgcolor=c_row, text_color=is_alert_preview_mode ? color.orange : color.aqua, text_halign=text.align_right, text_size=t_size)
        
        // --- Row 7: Volume Status ---
        vol_ratio = not na(vx1_vol) and vol_ma > 0 ? vx1_vol / vol_ma : 0
        vol_txt = is_vol_spike ? "🔥 SPIKE" : is_vol_high ? "⚡ HIGH" : "◦ NORM"
        vol_col = is_vol_spike ? color.yellow : is_vol_high ? color.aqua : color.silver
        table.cell(panel, 0, 7, vol_txt, bgcolor=c_row, text_color=vol_col, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 7, str.tostring(vol_ratio, "#.#") + "x", bgcolor=c_row, text_color=vol_col, text_halign=text.align_right, text_size=t_size)
        
        // --- Row 8: STRUCTURE 分组标题 ---
        table.cell(panel, 0, 8, "STRUCTURE", bgcolor=c_group, text_color=c_label, text_halign=text.align_left, text_size=size.tiny)
        table.cell(panel, 1, 8, "", bgcolor=c_group, text_color=c_label, text_size=size.tiny)
        
        // --- Row 9: Term Z ---
        z_dir = z_momentum_bullish ? "▼" : z_momentum_bearish ? "▲" : "→"
        z_col = z < -thresh_strong ? color.lime : z > thresh_strong ? color.red : color.silver
        table.cell(panel, 0, 9, "Z " + str.tostring(z, "#.##"), bgcolor=c_row, text_color=z_col, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 9, z_dir, bgcolor=c_row, text_color=z_momentum_bullish ? color.lime : z_momentum_bearish ? color.orange : color.silver, text_halign=text.align_right, text_size=t_size)
        
        // --- Row 10: Contango ---
        contango_emoji = contango_pct < 0 ? "⚠️" : "✓"
        contango_col = contango_pct < 0 ? color.red : color.lime
        table.cell(panel, 0, 10, "Contango", bgcolor=c_row, text_color=c_label, text_halign=text.align_left, text_size=t_size)
        table.cell(panel, 1, 10, contango_emoji + str.tostring(contango_pct, "#.#") + "%", bgcolor=c_row, text_color=contango_col, text_halign=text.align_right, text_size=t_size)
        
        // --- Row 11: STATS 分组标题 ---
        stats_header = is_stats_daily_chart ? "STATS (" + str.tostring(stats_lookback_years) + "Y)" : "STATS (1D)"
        table.cell(panel, 0, 11, stats_header, bgcolor=c_group, text_color=c_label, text_halign=text.align_left, text_size=size.tiny)
        table.cell(panel, 1, 11, "", bgcolor=c_group, text_color=c_label, text_size=size.tiny)
        
        // --- Row 12: CRASH + STRONG 统计 ---
        if show_signal_stats
            if not is_stats_daily_chart
                table.cell(panel, 0, 12, "1D ONLY", bgcolor=c_row, text_color=c_label, text_halign=text.align_left, text_size=t_size)
                table.cell(panel, 1, 12, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
                table.cell(panel, 0, 13, "Use daily chart", bgcolor=c_row, text_color=c_label, text_halign=text.align_left, text_size=t_size)
                table.cell(panel, 1, 13, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
                table.cell(panel, 0, 14, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
                table.cell(panel, 1, 14, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
                table.cell(panel, 0, 15, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
                table.cell(panel, 1, 15, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            else
                stats_left = f_stats_cell("🚨", crash_buy_evaluated_count, crash_buy_win_rate, crash_buy_avg_return, stats_ready)
                stats_right = f_stats_cell("🟢", strong_buy_evaluated_count, strong_buy_win_rate, strong_buy_avg_return, stats_ready)
                stats_dip = f_stats_cell("🟡", buy_dip_evaluated_count, buy_dip_win_rate, buy_dip_avg_return, stats_ready)
                stats_sell_left = f_stats_cell("🔥", euphoria_sell_evaluated_count, euphoria_sell_win_rate, euphoria_sell_avg_return, stats_ready)
                stats_sell_right = f_stats_cell("🔴", strong_sell_evaluated_count, strong_sell_win_rate, strong_sell_avg_return, stats_ready)
                stats_hedge = f_stats_cell("🟠", sell_hedge_evaluated_count, sell_hedge_win_rate, sell_hedge_avg_return, stats_ready)
                crash_col = stats_ready ? (crash_buy_avg_return >= 0 ? color.lime : color.red) : c_label
                strong_col = stats_ready ? (strong_buy_avg_return >= 0 ? color.lime : color.red) : c_label
                dip_col = stats_ready ? (buy_dip_avg_return >= 0 ? color.lime : color.red) : c_label
                euphoria_col = stats_ready ? (euphoria_sell_avg_return <= 0 ? color.lime : color.red) : c_label
                sell_strong_col = stats_ready ? (strong_sell_avg_return <= 0 ? color.lime : color.red) : c_label
                hedge_col = stats_ready ? (sell_hedge_avg_return <= 0 ? color.lime : color.red) : c_label
                table.cell(panel, 0, 12, stats_left, bgcolor=c_row, text_color=crash_col, text_halign=text.align_left, text_size=t_size)
                table.cell(panel, 1, 12, stats_right, bgcolor=c_row, text_color=strong_col, text_halign=text.align_right, text_size=t_size)
            
                // --- Row 13: BUY DIP 统计 ---
                table.cell(panel, 0, 13, stats_dip, bgcolor=c_row, text_color=dip_col, text_halign=text.align_left, text_size=t_size)
                table.cell(panel, 1, 13, stats_ready ? "N=Evaluated" : "Need full window", bgcolor=c_row, text_color=c_label, text_halign=text.align_right, text_size=size.tiny)
                table.cell(panel, 0, 14, stats_sell_left, bgcolor=c_row, text_color=euphoria_col, text_halign=text.align_left, text_size=t_size)
                table.cell(panel, 1, 14, stats_sell_right, bgcolor=c_row, text_color=sell_strong_col, text_halign=text.align_right, text_size=t_size)
                table.cell(panel, 0, 15, stats_hedge, bgcolor=c_row, text_color=hedge_col, text_halign=text.align_left, text_size=t_size)
                table.cell(panel, 1, 15, stats_ready ? "Win = Ref<=0" : "Need full window", bgcolor=c_row, text_color=c_label, text_halign=text.align_right, text_size=size.tiny)
        else
            table.cell(panel, 0, 12, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            table.cell(panel, 1, 12, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            table.cell(panel, 0, 13, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            table.cell(panel, 1, 13, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            table.cell(panel, 0, 14, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            table.cell(panel, 1, 14, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            table.cell(panel, 0, 15, "", bgcolor=c_row, text_color=c_label, text_size=t_size)
            table.cell(panel, 1, 15, "", bgcolor=c_row, text_color=c_label, text_size=t_size)

// ========== 10. SMART ALERT (Unified Alert System v7.5) ==========
// 基于 Adaptive RSI Pro 的智能警报优化：
// 1. 信号等级系统 (Lv1-3) - 实现优先级分级
// 2. varip K线内去重 - 同一K线弱信号不重复触发
// 3. 等级升级触发 - 出现更强信号时立即触发新警报
// 4. VIX Regime 自适应冷却 - 跨K线的额外过滤层
// 5. 日内方向锁 - 同方向同级别当日只发一次，仅允许升级

// varip: 追踪当前K线内已观察到的最高信号等级。
// 即使提醒被盘后策略或冷却拦截，也要记账避免在同一方向上重放。
varip int buy_alert_level_sent = 0
varip int sell_alert_level_sent = 0

// varip: 实时bar回滚安全。alert 发出后即刻记账，避免同一实时bar或后续bar重复重放。
varip int last_buy_alert_bar = 0
varip int last_sell_alert_bar = 0

// v7.7: 追踪上一根K线的信号等级，用于检测跨K线升级
varip int prev_bar_buy_level = 0
varip int prev_bar_sell_level = 0

// v7.12: 日内方向锁（同方向同级别只提醒一次）
varip int buy_day_latch_level = 0
varip int sell_day_latch_level = 0
varip int buy_day_latch_id = 0
varip int sell_day_latch_id = 0

// 新K线开始时重置当前K线已观察等级，并保存上一K线等级
if barstate.isnew
    prev_bar_buy_level := buy_alert_level_sent
    prev_bar_sell_level := sell_alert_level_sent
    buy_alert_level_sent := 0
    sell_alert_level_sent := 0
    if has_new_chart_day
        buy_day_latch_level := 0
        sell_day_latch_level := 0
        buy_day_latch_id := 0
        sell_day_latch_id := 0

// VIX Regime 自适应冷却：高波动减半，低波动加倍
// v7.13 (M3): math.max 防止 base=1 时整除截断得 0 / Guard: int division truncates, base=1 must not yield 0 cooldown
adaptive_cooldown = vix_regime == 3 ? math.max(1, math.round(alert_cooldown_base / 2)) : vix_regime == 1 ? alert_cooldown_base * 2 : alert_cooldown_base

if enable_smart_alert
    // ===== 买入信号聚合 =====
    alert_buy_crash = is_alert_preview_mode ? preview_crash_buy : pending_confirmed_buy_level == 3
    alert_buy_strong = is_alert_preview_mode ? preview_strong_buy : pending_confirmed_buy_level == 2
    alert_buy_dip = is_alert_preview_mode ? preview_buy_dip : pending_confirmed_buy_level == 1
    has_buy_signal = alert_buy_crash or alert_buy_strong or alert_buy_dip
    has_buy_signal_prev = is_alert_preview_mode ? ((alert_buy_crash[1] == true) or (alert_buy_strong[1] == true) or (alert_buy_dip[1] == true)) : false
    current_buy_level = f_buy_signal_level(alert_buy_crash, alert_buy_strong, alert_buy_dip)
    prev_buy_level_ref = is_alert_preview_mode ? prev_bar_buy_level : 0
    is_rising_edge_buy = is_alert_preview_mode ? (has_buy_signal and not has_buy_signal_prev and current_buy_level > buy_alert_level_sent) : false
    is_cross_bar_upgrade_buy = is_alert_preview_mode ? (has_buy_signal and current_buy_level > prev_bar_buy_level and current_buy_level > buy_alert_level_sent) : false
    is_new_buy = is_rising_edge_buy or is_cross_bar_upgrade_buy
    active_buy_latch_level = buy_day_latch_id == chart_day_id ? buy_day_latch_level : 0
    is_buy_day_latch_upgrade = current_buy_level > active_buy_latch_level
    should_latch_extended_buy = extended_preview_bar and is_new_buy and is_buy_day_latch_upgrade
    should_emit_buy = is_alert_preview_mode ? (allow_alert_now and is_new_buy and is_buy_day_latch_upgrade and (bar_index - last_buy_alert_bar > adaptive_cooldown)) : (confirmed_emit_now and current_buy_level > 0 and pending_confirmed_structure_day != emitted_confirmed_buy_day)
    
    if should_emit_buy
        // 构建消息头 (含等级标签 + 升级标记)
        upgrade_marker = current_buy_level > prev_buy_level_ref and prev_buy_level_ref > 0 ? "⬆️" : ""
        level_txt = current_buy_level == 3 ? "[Lv3🔥]" : current_buy_level == 2 ? "[Lv2]" : "[Lv1]"
        msg = str.format("{0}: 🟢 BUY {1} {2}{3} → ", syminfo.ticker, alert_mode_tag, level_txt, upgrade_marker)
        
        // 添加触发的信号标签
        if alert_buy_crash
            msg := msg + "🚨CRASH "
        if alert_buy_strong
            msg := msg + "🟢STRONG "
        if alert_buy_dip
            msg := msg + "🟡DIP "
        
        // 添加上下文：Score, Z, VIX Regime, 指数趋势
        msg := msg + str.format("| Score:{0} Z:{1,number,#.##} VIX:{2,number,#.#}({3}) {4}", 
            is_alert_preview_mode ? score : pending_confirmed_score,
            is_alert_preview_mode ? z : pending_confirmed_z,
            is_alert_preview_mode ? vix : pending_confirmed_vix,
            is_alert_preview_mode ? vix_regime_txt : pending_confirmed_vix_regime_txt,
            is_alert_preview_mode ? trend_status_txt : pending_confirmed_trend_status_txt)
        msg := msg + " | " + alert_mode_desc
        if is_hybrid_alert_mode
            msg := msg + " hybrid daily+chart"
        
        alert(msg, alert_freq)
        if is_alert_preview_mode
            last_buy_alert_bar := bar_index
            buy_day_latch_level := current_buy_level
            buy_day_latch_id := chart_day_id
        else
            emitted_confirmed_buy_day := pending_confirmed_structure_day

    if should_latch_extended_buy
        buy_day_latch_level := current_buy_level
        buy_day_latch_id := chart_day_id

    if is_new_buy
        buy_alert_level_sent := current_buy_level > buy_alert_level_sent ? current_buy_level : buy_alert_level_sent
    
    // ===== 卖出信号聚合 =====
    alert_sell_euphoria = is_alert_preview_mode ? preview_euphoria_sell : pending_confirmed_sell_level == 3
    alert_sell_strong = is_alert_preview_mode ? preview_strong_sell : pending_confirmed_sell_level == 2
    alert_sell_hedge = is_alert_preview_mode ? preview_sell_hedge : pending_confirmed_sell_level == 1
    has_sell_signal = alert_sell_euphoria or alert_sell_strong or alert_sell_hedge
    has_sell_signal_prev = is_alert_preview_mode ? ((alert_sell_euphoria[1] == true) or (alert_sell_strong[1] == true) or (alert_sell_hedge[1] == true)) : false
    current_sell_level = f_sell_signal_level(alert_sell_euphoria, alert_sell_strong, alert_sell_hedge)
    prev_sell_level_ref = is_alert_preview_mode ? prev_bar_sell_level : 0
    
    is_rising_edge_sell = is_alert_preview_mode ? (has_sell_signal and not has_sell_signal_prev and current_sell_level > sell_alert_level_sent) : false
    is_cross_bar_upgrade_sell = is_alert_preview_mode ? (has_sell_signal and current_sell_level > prev_bar_sell_level and current_sell_level > sell_alert_level_sent) : false
    is_new_sell = is_rising_edge_sell or is_cross_bar_upgrade_sell
    active_sell_latch_level = sell_day_latch_id == chart_day_id ? sell_day_latch_level : 0
    is_sell_day_latch_upgrade = current_sell_level > active_sell_latch_level
    should_latch_extended_sell = extended_preview_bar and is_new_sell and is_sell_day_latch_upgrade
    should_emit_sell = is_alert_preview_mode ? (allow_alert_now and is_new_sell and is_sell_day_latch_upgrade and (bar_index - last_sell_alert_bar > adaptive_cooldown)) : (confirmed_emit_now and current_sell_level > 0 and pending_confirmed_structure_day != emitted_confirmed_sell_day)
    
    if should_emit_sell
        // 构建消息头 (含等级标签 + 升级标记)
        upgrade_marker = current_sell_level > prev_sell_level_ref and prev_sell_level_ref > 0 ? "⬆️" : ""
        level_txt = current_sell_level == 3 ? "[Lv3🔥]" : current_sell_level == 2 ? "[Lv2]" : "[Lv1]"
        msg = str.format("{0}: 🔴 SELL {1} {2}{3} → ", syminfo.ticker, alert_mode_tag, level_txt, upgrade_marker)
        
        if alert_sell_euphoria
            msg := msg + "🔥EUPHORIA "
        if alert_sell_strong
            msg := msg + "🔴STRONG "
        if alert_sell_hedge
            msg := msg + "🟠HEDGE "
        
        // 添加上下文：Score, Z, SKEW, 指数趋势
        msg := msg + str.format("| Score:{0} Z:{1,number,#.##} SKEW:{2,number,#} {3}", 
            is_alert_preview_mode ? score : pending_confirmed_score,
            is_alert_preview_mode ? z : pending_confirmed_z,
            is_alert_preview_mode ? skew : pending_confirmed_skew,
            is_alert_preview_mode ? trend_status_txt : pending_confirmed_trend_status_txt)
        msg := msg + " | " + alert_mode_desc
        if is_hybrid_alert_mode
            msg := msg + " hybrid daily+chart"
        
        alert(msg, alert_freq)
        if is_alert_preview_mode
            last_sell_alert_bar := bar_index
            sell_day_latch_level := current_sell_level
            sell_day_latch_id := chart_day_id
        else
            emitted_confirmed_sell_day := pending_confirmed_structure_day

    if should_latch_extended_sell
        sell_day_latch_level := current_sell_level
        sell_day_latch_id := chart_day_id

    if is_new_sell
        sell_alert_level_sent := current_sell_level > sell_alert_level_sent ? current_sell_level : sell_alert_level_sent
